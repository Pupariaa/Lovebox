APP_ENV=production
APP_URL=https://your-domain.example
APP_DEBUG=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=change-me-database-name
DB_USER=change-me-database-user
DB_PASSWORD=change-me-database-password

JWT_SECRET=change-me-generate-a-64-char-random-hex-secret
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

MAIL_FROM=noreply@your-domain.example
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

INVITE_TOKEN_TTL=604800
LONG_POLL_MAX_SECONDS=15
REQUIRE_EMAIL_VERIFICATION=false

CORS_ALLOWED_ORIGINS=https://your-domain.example
TRUSTED_PROXIES=

OTA_STORAGE_PATH=
OTA_PUBLIC_URL=https://your-domain.example
OTA_ADMIN_KEY=change-me-ota-admin-key
ADMIN_API_KEY=change-me-admin-api-key
USB_DEBUG_TOKEN_SECRET=
USB_DEBUG_TOKEN_TTL=7200

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
